# --- Database Config ---
# PostgreSQL url (Neon/Supabase) or sqlite local file path (sqlite:///./cleanpro.db)
DATABASE_URL=sqlite:///./cleanpro.db

# --- Security ---
# Secret key for JWT token signature generation (create using: openssl rand -hex 32)
SECRET_KEY=5b8f9e1c2d3a4b5c6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d

# --- AI Chatbot Options ---
# Option A: OpenRouter API (Recommended for Cloud & Local - Free Tier)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=liquid/lfm-2.5-1.2b-instruct:free

# Option B: Hugging Face Inference API (Free Tier - Note: HF blocks this inside HF Spaces due to routing loops, but works locally)
HUGGINGFACE_API_KEY=your_hugging_face_token
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct

# Option C: Local Ollama Fallback (Default if no API keys are provided)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b

# --- CORS & Network ---
# Comma-separated list of allowed origins (production frontend url on Vercel)
ALLOWED_ORIGINS=http://localhost:5173,https://frontend-ten-lac-85.vercel.app

# --- Frontend Env Variable (set in Vercel or frontend/.env) ---
# VITE_API_BASE_URL=https://gayathrivprem-home-cleaning-backend.hf.space
