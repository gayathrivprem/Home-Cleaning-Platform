# --- Database Config ---
# PostgreSQL url (Neon/Supabase) or sqlite local file path (sqlite:///./cleanpro.db)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Security ---
# Secret key for JWT token signature generation (create using: openssl rand -hex 32)
SECRET_KEY=supersecretjwtkeythatshouldbelongandsecure

# --- AI Chatbot ---
# API Key for Hugging Face Inference API (Free Tier)
HUGGINGFACE_API_KEY=hf_your_huggingface_api_token
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct

# OR OpenRouter API Key (Optional fallback)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemma-2-9b-it:free

# --- CORS & Network ---
# Comma-separated list of allowed origins (production frontend url on Vercel)
ALLOWED_ORIGINS=https://your-frontend-app.vercel.app,http://localhost:5173

# --- Frontend Env Variable (set in Vercel) ---
# VITE_API_BASE_URL=https://your-backend-url.onrender.com
